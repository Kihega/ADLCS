# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (Render PostgreSQL) ─────────────────
DATABASE_URL=postgresql://user:password@host:5432/census_db

# ─── Redis (Upstash) ──────────────────────────────
REDIS_URL=rediss://:password@host:6379

# ─── JWT ──────────────────────────────────────────
JWT_ACCESS_SECRET=your-64-char-random-secret-here
JWT_REFRESH_SECRET=your-64-char-random-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (Resend) ───────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# ─── SMS (Africa's Talking) ───────────────────────
AT_API_KEY=your-africas-talking-key
AT_USERNAME=sandbox
AT_SENDER_ID=NBS-CENSUS

# ─── NIDA API ─────────────────────────────────────
NIDA_API_URL=https://api.nida.go.tz/v1
NIDA_API_KEY=your-nida-api-key

# ─── MoHCDGEC (Facility Registry) ────────────────
MOH_API_URL=https://api.moh.go.tz/v1
MOH_API_KEY=your-moh-api-key

# ─── RITA API ─────────────────────────────────────
RITA_API_URL=https://api.rita.go.tz/v1
RITA_API_KEY=your-rita-api-key

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Security ─────────────────────────────────────
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ─── Frontend URLs (CORS) ─────────────────────────
VERCEL_URL=https://your-project.vercel.app
WEB_URL=https://your-custom-domain.com

# PATCH-6: Set this URL in Render environment variables
# API_BASE_URL=https://your-app.onrender.com

# ─── Public backend URL (BUGFIX-2) ────────────────
# Used to build absolute links (e.g. certificate PDF URLs) that are
# returned to the frontend. Must match wherever this backend is deployed.
PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# ─── Added by fix_lint_v3.py ───
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
