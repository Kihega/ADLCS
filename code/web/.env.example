# ─────────────────────────────────────────────────────────────
# ADLCS Web Frontend — Environment Variables
# Copy to .env.local for local development (never commit .env.local)
# All variables must be prefixed VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────

# Backend API base URL — no trailing slash
# Development:  http://localhost:5000/api
# Production:   https://final-dissertation-s6j8.onrender.com/api
VITE_API_BASE_URL=https://final-dissertation-s6j8.onrender.com/api
