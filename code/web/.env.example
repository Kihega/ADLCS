# ─── Web Dashboard environment variables ─────────────────────────────────
# Copy this file to .env and fill in the real values.
# THIS IS THE ONLY PLACE backend URLs should be configured.
# There are no hardcoded fallback URLs anywhere in the web source code.

# The full base URL of your backend API (include /api suffix)
VITE_API_BASE_URL=https://your-backend.onrender.com/api
