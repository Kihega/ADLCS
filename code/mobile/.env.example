# ─── Mobile app environment variables ────────────────────────────────────
# Copy this file to .env and fill in the real values.
# THIS IS THE ONLY PLACE backend URLs should be configured.
# There are no hardcoded fallback URLs anywhere in the mobile source code.

# The full base URL of your backend API (include /api suffix)
EXPO_PUBLIC_API_URL=https://your-backend.onrender.com/api
